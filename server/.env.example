# ── Server ──
PORT=3001
JWT_SECRET=thotheauphis-merkaba-secret-change-me
CORS_ORIGIN=https://hermaeuswaelon.github.io

# ── Admin Account ──
ADMIN_MEMBER_ID=veyron

# ── Model Provider Keys (set what you have) ──

# Primary: DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key

# Fallback 1: OpenRouter (covers Claude, Gemini, Llama, etc.)
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Fallback 2: xAI Grok
XAI_API_KEY=your-xai-key

# ── Hermes Bridge ──
# Set to "true" to route Sovereign harness through this machine's Hermes agent
# Requires hermes CLI installed and profile "thotheauphis" configured
HERMES_BRIDGE=true

# ── Plans & Pricing ──
# Default credits given to new members
DEFAULT_CREDITS=1000
